# Core environment
EPSA_ENV=local
EPSA_DEBUG=true
EPSA_SECRET_KEY=change-me
EPSA_JWT_SECRET=change-me-too

# Local URL helpers
EPSA_LOCAL_BACKEND_HOST=127.0.0.1
EPSA_LOCAL_BACKEND_PORT=5000
EPSA_LOCAL_FRONTEND_PORTS=5000,5500,5173,3000

# Public/app URLs
EPSA_APP_URL=http://127.0.0.1:5000
EPSA_API_BASE_URL=http://127.0.0.1:5000/api
EPSA_CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5500,http://127.0.0.1:5500

# Database
EPSA_DATABASE_URL=sqlite:///backend/epsa.db
DATABASE_URL=

# Uploads and storage
EPSA_UPLOAD_DIR=backend/uploads
EPSA_STORAGE_MODE=local
EPSA_PUBLIC_UPLOAD_FOLDERS=profiles,news,partners,partner_gallery,appointees,feed,clubs,club_activities,manifestos,governance_docs,training_graphics
EPSA_PRIVATE_UPLOAD_FOLDERS=slips,receipts,fin_receipts,proposals
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=uploads
EPSA_S3_BUCKET=
EPSA_S3_REGION=
EPSA_S3_ENDPOINT_URL=
EPSA_S3_ACCESS_KEY_ID=
EPSA_S3_SECRET_ACCESS_KEY=
EPSA_S3_PUBLIC_BASE_URL=
EPSA_S3_PUBLIC_PREFIX=public
EPSA_S3_PRIVATE_PREFIX=private

# JWT delivery
EPSA_AUTH_TOKEN_MODE=local_storage
EPSA_JWT_ACCESS_EXPIRES_SECONDS=3600
EPSA_JWT_REFRESH_EXPIRES_SECONDS=604800
EPSA_JWT_COOKIE_SECURE=false
EPSA_JWT_COOKIE_SAMESITE=Lax
EPSA_JWT_COOKIE_DOMAIN=

# Email / password reset
EPSA_EMAIL_PROVIDER=resend
EPSA_RESEND_API_KEY=
EPSA_RESEND_FROM_EMAIL=
EPSA_BOOTSTRAP_ADMIN_USERNAME=
EPSA_BOOTSTRAP_ADMIN_PASSWORD=
EPSA_BOOTSTRAP_ADMIN_EMAIL=
EPSA_BOOTSTRAP_ADMIN_FIRST_NAME=EPSA
EPSA_BOOTSTRAP_ADMIN_FATHER_NAME=Administrator
EPSA_BOOTSTRAP_ADMIN_TOTP_SECRET=
EPSA_PASSWORD_RESET_TTL_SECONDS=3600
EPSA_PASSWORD_RESET_URL=http://127.0.0.1:5000/login.html

# OTP / admin 2FA
EPSA_OTP_TTL_SECONDS=600
EPSA_OTP_PROOF_TTL_SECONDS=1800
EPSA_SHOW_OTP_IN_RESPONSE=false
EPSA_REQUIRE_ADMIN_TOTP=false
EPSA_ADMIN_TOTP_SECRET=
EPSA_ALLOW_LOCAL_ADMIN_TOTP_BYPASS=true

# Telegram Mini App
EPSA_TELEGRAM_BOT_TOKEN=

# Runtime protections
EPSA_RATE_LIMIT_ENABLED=true
EPSA_BIOMETRIC_WORKERS=2
EPSA_BIOMETRIC_TIMEOUT_SECONDS=45
EPSA_MAX_CONTENT_LENGTH_MB=20
EPSA_ENABLE_DEV_SEED=false

# Production server
EPSA_GUNICORN_BIND=0.0.0.0:5000
EPSA_GUNICORN_WORKERS=2
